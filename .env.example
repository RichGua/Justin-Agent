# Copy this file to `.env` and fill in your own values.
# `.env` is ignored by git.

# Core runtime
JUSTIN_MODEL_PROVIDER=openai
JUSTIN_MODEL_NAME=gpt-4.1-mini
JUSTIN_API_BASE=https://api.openai.com/v1
JUSTIN_API_KEY=your_api_key_here
JUSTIN_MODEL_TEMPERATURE=0.3
JUSTIN_MODEL_TOP_P=0.95
JUSTIN_MODEL_MAX_TOKENS=1024
JUSTIN_MODEL_TIMEOUT_SECONDS=60
JUSTIN_MODEL_RETRY_MAX_TOKENS=8192

# Optional server config
JUSTIN_HOST=127.0.0.1
JUSTIN_PORT=8765

# Optional WeChat gateway config
JUSTIN_WECHAT_ENABLED=false
JUSTIN_WECHAT_ACCOUNT_ID=
JUSTIN_WECHAT_TOKEN=
JUSTIN_WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
JUSTIN_WECHAT_AUTO_REPLY_PREFIX=[Justin]
JUSTIN_WECHAT_DM_POLICY=open
JUSTIN_WECHAT_ALLOWED_USERS=
JUSTIN_WECHAT_GROUP_POLICY=disabled
JUSTIN_WECHAT_GROUP_ALLOWED_USERS=
