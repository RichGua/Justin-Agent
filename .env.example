# Copy this file to `.env` and fill in your own values.
# `.env` is ignored by git.

# Core runtime
JUSTIN_MODEL_PROVIDER=openai
JUSTIN_MODEL_NAME=gpt-4.1-mini
JUSTIN_API_BASE=https://api.openai.com/v1
JUSTIN_API_KEY=your_api_key_here

# Optional server config
JUSTIN_HOST=127.0.0.1
JUSTIN_PORT=8765
